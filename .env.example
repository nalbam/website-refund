# Slack Bot Token (chat:write, channels:history, groups:history, reactions:read)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack Signing Secret (reaction_added 이벤트 서명 검증용)
SLACK_SIGNING_SECRET=your-signing-secret-here

# (선택) 소모임 목록을 코드 상수 대신 환경 변수로 관리하고 싶을 때 사용.
# 지정되면 lib/config.ts의 SUBGROUPS 상수보다 우선. 미설정/파싱 실패 시 상수로 폴백.
# 포맷: JSON 배열. 필수 필드 id/name/channelId, contactId는 선택.
# SUBGROUPS_JSON=[{"id":"aiengineering","name":"AI Engineering 소모임","channelId":"C07...","contactId":"nalbam"}]
